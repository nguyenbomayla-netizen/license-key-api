# MongoDB connection string (lấy từ MongoDB Atlas)
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/licensedb?retryWrites=true&w=majority

# Port server (thường để mặc định khi deploy)
PORT=5000

# Mật khẩu admin để revoke key (đổi thành chuỗi bí mật của bạn)
ADMIN_SECRET=Centifer123
